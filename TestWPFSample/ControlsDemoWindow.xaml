<Window x:Class="TestWPFSample.ControlsDemoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Selection + Data Controls Demo"
        Width="900"
        Height="650"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <TabControl>

            <TabItem Header="ListView">
                <ListView Margin="12"
                          FontSize="20">
                    <ListViewItem Content="First item - 1"/>
                    <ListViewItem Content="Second item - 2"/>
                    <ListViewItem Content="Third item - 3"/>
                    <ListViewItem Content="Fourth item - 4"/>
                </ListView>
            </TabItem>

            <TabItem Header="TreeView">
                <TreeView Margin="12">
                    <TreeViewItem Header="Project">
                        <TreeViewItem Header="MainWindow.xaml"/>
                        <TreeViewItem Header="App.xaml"/>
                        <TreeViewItem Header="Themes">
                            <TreeViewItem Header="Light.xaml"/>
                            <TreeViewItem Header="Dark.xaml"/>
                        </TreeViewItem>
                        <TreeViewItem Header="TestText"/>
                        <TreeViewItem Header="Test">
                            <TreeViewItem Header="text1"/>
                            <TreeViewItem Header="text2"/>
                            <TreeViewItem Header="text3"/>
                        </TreeViewItem>
                    </TreeViewItem>
                </TreeView>
            </TabItem>

            <TabItem Header="DataGrid">

                    <DataGrid x:Name="DemoDataGrid"
                              Margin="12"
                              AutoGenerateColumns="True"/>
            </TabItem>

        </TabControl>
    </Grid>
</Window>