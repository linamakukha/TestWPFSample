<Window x:Class="TestWPFSample.DetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Details Window"
        Height="420"
        Width="560"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Style x:Key="PulseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="180"/>
            <Setter Property="Height" Value="56"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#FF0F766E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                             From="1.0"
                                             To="1.10"
                                             Duration="0:0:0.7"/>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                             From="1.0"
                                             To="1.10"
                                             Duration="0:0:0.7"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#FFF8FAFC" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White"
                CornerRadius="14"
                Padding="18"
                BorderBrush="#FFE2E8F0"
                BorderThickness="1"
                Margin="0,0,0,14">
            <TextBlock x:Name="AnimatedHeader"
                       Text="Второй экран"
                       FontSize="30"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Opacity="0"/>
        </Border>

        <TextBlock Grid.Row="1"
                   x:Name="DetailsStatus"
                   Text="Статус: готов к тесту"
                   FontSize="18"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,14"/>

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="14"
                Padding="20"
                BorderBrush="#FFE2E8F0"
                BorderThickness="1">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="На кнопку ниже удобно ставить breakpoint и менять код или XAML через Hot Reload."
                           TextWrapping="Wrap"
                           FontSize="15"
                           Margin="0,0,0,18"/>

                <Button x:Name="ActionButton"
                        Content="Тестовая кнопка"
                        Style="{StaticResource PulseButtonStyle}"
                        HorizontalAlignment="Center"
                        Click="ActionButton_Click"/>

                <TextBlock x:Name="ResultText"
                           Text="Ожидание действия"
                           FontSize="16"
                           Margin="0,20,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Button Grid.Row="3"
                Content="Закрыть"
                Width="120"
                Height="38"
                Margin="0,14,0,0"
                HorizontalAlignment="Right"
                Click="Close_Click"/>
    </Grid>
</Window>
