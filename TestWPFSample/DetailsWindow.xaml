<Window x:Class="TestWPFSample.DetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Details Window"
        Height="520"
        Width="680"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">
    <Window.Resources>

        <Style x:Key="PulseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="210"/>
            <Setter Property="Height" Value="58"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <RotateTransform Angle="0"/>
                    </TransformGroup>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Children[0].ScaleX"
                                             From="1.0"
                                             To="1.12"
                                             Duration="0:0:0.7"/>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Children[0].ScaleY"
                                             From="1.0"
                                             To="1.12"
                                             Duration="0:0:0.7"/>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Children[1].Angle"
                                             From="-2"
                                             To="2"
                                             Duration="0:0:0.35"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid Background="{DynamicResource AppBackgroundBrush}" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock x:Name="AnimatedHeader"
                           Text="Второй экран"
                           FontSize="32"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Opacity="0"/>

                <TextBlock x:Name="SlidingSubtitle"
                           Text="Здесь удобно ставить breakpoint и менять код/XAML."
                           FontSize="15"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"
                           Opacity="0"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="1"
                   x:Name="DetailsStatus"
                   Text="Статус: готов к тесту"
                   FontSize="18"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,14"/>

        <Border Grid.Row="2"
                Style="{StaticResource CardStyle}">
            <StackPanel VerticalAlignment="Center">
                <Canvas Height="110"
                        Background="{DynamicResource ListItemBrush}"
                        ClipToBounds="True"
                        Margin="0,0,0,18">

                    <Ellipse x:Name="ColorChangingEllipse"
                             Canvas.Left="35"
                             Canvas.Top="25"
                             Width="58"
                             Height="58"
                             Fill="{DynamicResource PrimaryBrush}"/>

                    <Rectangle x:Name="JumpingRect"
                               Canvas.Left="150"
                               Canvas.Top="38"
                               Width="70"
                               Height="42"
                               RadiusX="8"
                               RadiusY="8"
                               Fill="{DynamicResource AccentBrush}"/>

                    <TextBlock Text="Color + Translate animation"
                               Canvas.Left="260"
                               Canvas.Top="42"
                               FontSize="20"
                               FontWeight="SemiBold"/>
                </Canvas>

                <Button x:Name="ActionButton"
                        Content="Тестовая кнопка"
                        Style="{StaticResource PulseButtonStyle}"
                        HorizontalAlignment="Center"
                        Click="ActionButton_Click"/>

                <TextBlock x:Name="ResultText"
                           Text="Ожидание действия"
                           FontSize="16"
                           Margin="0,20,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Button Grid.Row="3"
                Content="Закрыть"
                Style="{StaticResource PrimaryButtonStyle}"
                Width="120"
                HorizontalAlignment="Right"
                Click="Close_Click"/>
    </Grid>
</Window>