<Window x:Class="TestWPFSample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TestWPFSample"
        Title="WPF Hot Reload Demo"
        Height="760"
        Width="1120"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Window.Resources>

        <Storyboard x:Key="RotateSquareStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="RotatingSquare"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                             From="0"
                             To="360"
                             Duration="0:0:4"/>
        </Storyboard>

        <Storyboard x:Key="MoveCircleStoryboard" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="MovingCircle"
                             Storyboard.TargetProperty="(Canvas.Left)"
                             From="20"
                             To="220"
                             Duration="0:0:2">
                <DoubleAnimation.EasingFunction>
                    <BounceEase Bounces="3" Bounciness="2"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="SkewTextStoryboard" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="SkewedText"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(SkewTransform.AngleX)"
                             From="-8"
                             To="8"
                             Duration="0:0:1.2"/>
        </Storyboard>

    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Background="{DynamicResource AppBackgroundBrush}" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="0.7*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,16,0">

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="WPF Hot Reload Demo"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Margin="0,0,0,8"/>

                        <local:HotReloadTestControl StatusText="Hello Hot Reload"
    Margin="0,0,0,16"/>

                        <TextBlock Text="Binding, commands, triggers, dictionaries, themes, 2D graphics, 3D graphics, animations and live updates."
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   FontSize="15"/>

                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <TextBlock Text="Theme:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>

                            <ComboBox Width="150"
                                      SelectedIndex="0"
                                      SelectionChanged="ThemeComboBox_SelectionChanged">
                                <ComboBoxItem Content="Light"/>
                                <ComboBoxItem Content="Dark"/>
                                <ComboBoxItem Content="Pastel"/>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Binding + DataTrigger"
                                   FontSize="21"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,14"/>

                        <TextBlock Text="Имя:" Margin="0,0,0,6"/>

                        <TextBox Text="{Binding UserName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Height="38"
                                 FontSize="14"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="{Binding StatusText}"
                                   FontSize="18"
                                   Margin="0,0,0,8">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                    <Setter Property="FontWeight" Value="Normal"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsHighlightEnabled}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <CheckBox Content="Подсветить статус"
                                  Foreground="{DynamicResource TextBrush}"
                                  IsChecked="{Binding IsHighlightEnabled, Mode=TwoWay}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Commands + Second Window"
                                   FontSize="21"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,14"/>

                        <WrapPanel>
                            <Button Content="Добавить сообщение"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding AddMessageCommand}"/>

                            <Button Content="Увеличить счетчик"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding IncreaseCounterCommand}"/>

                            <Button Content="Открыть второй экран"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="OpenDetails_Click"/>
                            
                            <Button Content="Open Controls Demo"
                                    Click="OpenControlsDemo_Click"
                                    Style="{StaticResource PrimaryButtonStyle}"/>
                        </WrapPanel>

                        <TextBlock Text="{Binding Counter, StringFormat=Counter: {0}}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="2D Graphics + разные анимации"
                                   FontSize="21"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,14"/>

                        <Canvas Height="210"
                                Background="{DynamicResource ListItemBrush}"
                                ClipToBounds="True">

                            <Path Fill="{DynamicResource ShapeAccentBrush}"
                                  Stroke="{DynamicResource BorderBrushSoft}"
                                  StrokeThickness="2"
                                  Data="M 20,150 C 80,40 150,240 240,80 S 360,120 420,40"
                                  Opacity="0.65"/>

                            <Ellipse x:Name="MovingCircle"
                                     Canvas.Left="20"
                                     Canvas.Top="40"
                                     Width="54"
                                     Height="54"
                                     Fill="{DynamicResource AccentBrush}"/>

                            <Rectangle x:Name="RotatingSquare"
                                       Canvas.Left="330"
                                       Canvas.Top="95"
                                       Width="70"
                                       Height="70"
                                       RadiusX="10"
                                       RadiusY="10"
                                       Fill="{DynamicResource ShapeBrush}"
                                       RenderTransformOrigin="0.5,0.5">
                                <Rectangle.RenderTransform>
                                    <RotateTransform Angle="0"/>
                                </Rectangle.RenderTransform>
                            </Rectangle>

                            <TextBlock x:Name="SkewedText"
                                       Canvas.Left="110"
                                       Canvas.Top="150"
                                       Text="Skew animation"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       RenderTransformOrigin="0.5,0.5">
                                <TextBlock.RenderTransform>
                                    <SkewTransform AngleX="0"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Canvas>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="3D Graphics"
                                   FontSize="21"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,14"/>

                        <Viewport3D Height="260">
                            <Viewport3D.Camera>
                                <PerspectiveCamera Position="2,2,4"
                                                   LookDirection="-2,-2,-4"
                                                   UpDirection="0,1,0"
                                                   FieldOfView="60"/>
                            </Viewport3D.Camera>

                            <ModelVisual3D>
                                <ModelVisual3D.Content>
                                    <DirectionalLight Color="White" Direction="-1,-1,-2"/>
                                </ModelVisual3D.Content>
                            </ModelVisual3D>

                            <ModelVisual3D>
                                <ModelVisual3D.Content>
                                    <GeometryModel3D>
                                        <GeometryModel3D.Geometry>
                                            <MeshGeometry3D
                                                Positions="-1,-1,0  1,-1,0  1,1,0  -1,1,0"
                                                TriangleIndices="0 1 2  0 2 3"
                                                TextureCoordinates="0,1 1,1 1,0 0,0"/>
                                        </GeometryModel3D.Geometry>

                                        <GeometryModel3D.Material>
                                            <DiffuseMaterial Brush="{DynamicResource PrimaryBrush}"/>
                                        </GeometryModel3D.Material>

                                        <GeometryModel3D.BackMaterial>
                                            <DiffuseMaterial Brush="{DynamicResource AccentBrush}"/>
                                        </GeometryModel3D.BackMaterial>

                                        <GeometryModel3D.Transform>
                                            <RotateTransform3D>
                                                <RotateTransform3D.Rotation>
                                                    <AxisAngleRotation3D x:Name="PlaneRotation"
                                                                         Axis="0,1,0"
                                                                         Angle="0"/>
                                                </RotateTransform3D.Rotation>
                                            </RotateTransform3D>
                                        </GeometryModel3D.Transform>
                                    </GeometryModel3D>
                                </ModelVisual3D.Content>
                            </ModelVisual3D>
                        </Viewport3D>
                    </StackPanel>
                </Border>

            </StackPanel>

            <StackPanel Grid.Column="1">
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Live Messages"
                                   FontSize="21"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,14"/>

                        <ListBox ItemsSource="{Binding Messages}"
                                 Height="430"
                                 BorderThickness="0"
                                 Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource ListItemBrush}"
                                            CornerRadius="10"
                                            Padding="10"
                                            Margin="0,0,0,8">
                                        <TextBlock Text="{Binding}"
                                                   TextWrapping="Wrap"/>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Hot Reload playground"
                                   FontSize="21"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Что удобно менять: темы, DynamicResource, Storyboard Duration/To, Path Data, Button Style, Binding text, code-behind обработчики."
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
            
            <StackPanel Grid.Column="2">
                <Border Style="{StaticResource AccentCardStyle}">
                <StackPanel Margin="0,12,0,0">

                    <TextBlock Text="Настройки"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"/>

                    <RadioButton Content="Первый вариант"
                                 GroupName="OptionsGroup"
                                 IsChecked="True"
                                 Margin="0,0,0,8"/>

                    <RadioButton Content="Второй вариант"
                                 GroupName="OptionsGroup"
                                 Margin="0,0,0,16"/>

                    <TextBlock Text="Комментарий:"
                               Margin="0,0,0,6"/>

                    <TextBox Height="36"
                             Text="New text"
                             Margin="0,0,0,16"/>

                    <TextBlock Text="Дата:"
                               Margin="0,0,0,6"/>

                    <DatePicker x:Name="MyDatePicker"
                                Margin="0,10,20,20"/>
                    
                    <TextBlock Text="One more text:"
                               Margin="0,0,0,6"/>

                </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">

                    <StackPanel>

                        <TextBlock Text="DocumentViewer Demo"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

                        <DocumentViewer x:Name="DemoDocumentViewer"
                        Height="300"/>

                    </StackPanel>

                </Border>
                
                <Border Style="{StaticResource CardStyle}">

                    <Grid Margin="8">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Complex nested collection"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,0,0,12"/>

                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding Messages}">

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    
                                    <Grid Margin="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Background="{DynamicResource ListItemBrush}"
                                                Padding="10"
                                                CornerRadius="8">

                                            <StackPanel>
                                                <TextBlock Text="{Binding}"/>
                                                <TextBlock Text="Extra line"/>
                                            </StackPanel>
                                        </Border>

                                        <Button Grid.Column="1"
                                                Content="{Binding}"
                                                Margin="8,0,0,0"
                                                Click="NestedItemButton_Click"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>

                        </ListBox>

                    </Grid>

                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>