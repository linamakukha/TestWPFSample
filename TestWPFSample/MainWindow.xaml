<Window x:Class="WpfHotReloadDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WPF Hot Reload Demo"
        Height="620"
        Width="900"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>

        <SolidColorBrush x:Key="PrimaryBrush" Color="#FF4F46E5"/>
        <SolidColorBrush x:Key="PanelBrush" Color="White"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#FFE2E8F0"/>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,10,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="150"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.88"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

    </Window.Resources>

    <Grid Background="#FFF8FAFC" Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="1.2*" />
        </Grid.ColumnDefinitions>

        <!-- Левая колонка -->
        <StackPanel Grid.Column="0" Margin="0,0,16,0">

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Главный экран"
                               FontSize="28"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="Это демо покрывает binding, commands, resources, triggers, live update и второе окно."
                               TextWrapping="Wrap"
                               FontSize="15"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Binding demo"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,14"/>

                    <TextBlock Text="Имя:"
                               Margin="0,0,0,6"/>

                    <TextBox Text="{Binding UserName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Height="34"
                             FontSize="14"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="{Binding StatusText}"
                               FontSize="18"
                               Margin="0,0,0,8">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#FF334155"/>
                                <Setter Property="FontWeight" Value="Normal"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHighlightEnabled}" Value="True">
                                        <Setter Property="Foreground" Value="#FFDC2626"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <CheckBox Content="Подсветить статус"
                              IsChecked="{Binding IsHighlightEnabled, Mode=TwoWay}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Commands + navigation"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,14"/>

                    <WrapPanel>
                        <Button Content="Добавить сообщение"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding AddMessageCommand}"/>

                        <Button Content="Увеличить счетчик"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding IncreaseCounterCommand}"/>

                        <Button Content="Открыть второй экран"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="OpenDetails_Click"/>
                    </WrapPanel>

                    <TextBlock Text="{Binding Counter, StringFormat=Counter: {0}}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Правая колонка -->
        <StackPanel Grid.Column="1">
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Live messages"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,14"/>

                    <ListBox ItemsSource="{Binding Messages}"
                             Height="360"
                             BorderThickness="0"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#FFF1F5F9"
                                        CornerRadius="8"
                                        Padding="10"
                                        Margin="0,0,0,8">
                                    <TextBlock Text="{Binding}"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
